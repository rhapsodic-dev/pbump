{
    "name": "rhapsodic/pbump",
    "description": "CLI tool for semantic release versioning and git tagging",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "release",
        "semver",
        "git",
        "composer"
    ],
    "homepage": "https://github.com/rhapsodic-dev/pbump",
    "support": {
        "issues": "https://github.com/rhapsodic-dev/pbump/issues",
        "source": "https://github.com/rhapsodic-dev/pbump"
    },
    "authors": [
        {
            "name": "rhapsodic.dev",
            "email": "rhapsodic.dev@gmail.com",
            "homepage": "https://github.com/rhapsodic-dev"
        },
        {
            "name": "Svyatoslav Fyodorov",
            "email": "intelrug@gmail.com",
            "homepage": "https://github.com/intelrug"
        },
        {
            "name": "TrenLok",
            "email": "trenlok.dev@gmail.com",
            "homepage": "https://github.com/trenlok"
        }
    ],
    "autoload": {
        "psr-4": {
            "Rhapsodic\\Pbump\\": "src/"
        }
    },
    "bin": [
        "bin/pbump"
    ],
    "scripts": {
        "lint": "@php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose",
        "format": "@php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose",
        "analyse": "@php vendor/bin/phpstan analyse --configuration phpstan.neon.dist --memory-limit=1G",
        "test": "@php vendor/bin/phpunit --configuration phpunit.xml --no-progress"
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "symfony/console": "^7.2 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        }
    }
}
